# Keystore configuration for Epycus release signing
# Copy this file to keystore.properties and fill in your values.
# keystore.properties is gitignored - DO NOT commit it.
#
# Generate a keystore:
#   keytool -genkey -v -keystore epycus-release.keystore -alias epycus -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=epycus-release.keystore
storePassword=your_store_password
keyAlias=epycus
keyPassword=your_key_password
