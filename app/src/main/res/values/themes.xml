        <item name="epAccentSecondary">@color/light_accent_secondary</item>
        <item name="epSuccess">@color/light_success</item>
        <item name="epWarning">@color/light_warning</item>
        <item name="epError">@color/light_error</item>
        <item name="epInfo">@color/light_info</item>
        <item name="epTextOnPrimary">@color/light_text_on_primary</item>
        <item name="epRoundedSm">2dp</item>
