<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@drawable/bg_card_rounded"
    android:layout_marginBottom="8dp"
    android:foreground="?attr/selectableItemBackground">

    <CheckBox
        android:id="@+id/cbSubTareaCompletada"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:buttonTint="?attr/epAccent" />

    <TextView
        android:id="@+id/tvSubTareaNombre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/nombre_subtarea"
        android:textSize="15sp"
        android:textColor="?attr/epTextPrimary"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/cbSubTareaCompletada"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="12dp"
        android:layout_marginTop="14dp" />

    <TextView
        android:id="@+id/tvSubTareaOrden"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/orden_subtarea"
        android:textSize="12sp"
        android:textColor="?attr/epTextTertiary"
        app:layout_constraintStart_toEndOf="@id/cbSubTareaCompletada"
        app:layout_constraintTop_toBottomOf="@id/tvSubTareaNombre"
        android:layout_marginStart="12dp" />

    <TextView
        android:id="@+id/tvSubTareaTiempo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tiempo_enfoque"
        android:textSize="12sp"
        android:textColor="?attr/epTextTertiary"
        app:layout_constraintStart_toEndOf="@id/tvSubTareaOrden"
        app:layout_constraintTop_toBottomOf="@id/tvSubTareaNombre"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp" />

    <ImageView
        android:id="@+id/btnEditarSubTarea"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_edit"
        app:tint="?attr/epTextTertiary"
        android:contentDescription="@string/editar_subtarea"
        android:padding="4dp"
        android:foreground="?attr/selectableItemBackground"
        app:layout_constraintEnd_toStartOf="@id/btnEliminarSubTarea"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginEnd="8dp" />

    <ImageView
        android:id="@+id/btnEliminarSubTarea"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_delete"
        app:tint="?attr/epError"
        android:contentDescription="@string/eliminar_subtarea"
        android:padding="4dp"
        android:foreground="?attr/selectableItemBackground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginEnd="12dp" />

</androidx.constraintlayout.widget.ConstraintLayout>