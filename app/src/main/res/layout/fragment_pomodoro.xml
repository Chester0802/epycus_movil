<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/epBgPrimary"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="16dp">

    <!-- Loading -->
    <LinearLayout
        android:id="@+id/loadingView"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:indeterminateTint="?attr/epAccent" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pomodoro"
        android:textSize="22sp"
        android:textColor="?attr/epTextPrimary"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvEstado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Foco"
        android:textSize="14sp"
        android:textColor="?attr/epAccent"
        android:layout_marginBottom="24dp" />

    <!-- Timer circle -->
    <LinearLayout
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:background="@drawable/bg_card_rounded"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTiempo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="25:00"
            android:textSize="56sp"
            android:textColor="?attr/epAccent"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Controls -->
    <Button
        android:id="@+id/btnControl"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:text="Iniciar"
        android:textAllCaps="false"
        android:textSize="12sp"
        android:backgroundTint="?attr/epAccent"
        app:cornerRadius="32dp"
        android:layout_marginTop="32dp" />

    <!-- Stats -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="32dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded">

            <TextView
                android:id="@+id/tvCiclos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ciclos: 0"
                android:textSize="13sp"
                android:textColor="?attr/epTextPrimary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded">

            <TextView
                android:id="@+id/tvTotalHoy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoy: 0"
                android:textSize="13sp"
                android:textColor="?attr/epTextPrimary" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
