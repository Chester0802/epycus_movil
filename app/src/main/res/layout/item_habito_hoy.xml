<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@drawable/bg_card_rounded"
    android:layout_marginBottom="8dp"
    android:foreground="?attr/selectableItemBackground">

    <CheckBox
        android:id="@+id/cbCompletado"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:buttonTint="?attr/epAccent" />

    <TextView
        android:id="@+id/tvHabitoNombre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/nombre_habito"
        android:textSize="15sp"
        android:textColor="?attr/epTextPrimary"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/cbCompletado"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tvHabitoXp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="14dp" />

    <TextView
        android:id="@+id/tvHabitoCategoria"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/categoria_ejemplo"
        android:textSize="12sp"
        android:textColor="?attr/epTextSecondary"
        app:layout_constraintStart_toEndOf="@id/cbCompletado"
        app:layout_constraintTop_toBottomOf="@id/tvHabitoNombre"
        app:layout_constraintEnd_toStartOf="@id/tvHabitoXp"
        android:layout_marginStart="12dp" />

    <TextView
        android:id="@+id/tvHabitoXp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/xp_ejemplo"
        android:textSize="12sp"
        android:textColor="?attr/epAccent"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginEnd="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
