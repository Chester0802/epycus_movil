<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/epBgPrimary"
    android:orientation="vertical"
    tools:context=".ui.auth.LoginActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Theme toggle -->
            <TextView
                android:id="@+id/btnToggleTheme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="@string/modo_oscuro"
                android:textSize="13sp"
                android:textColor="?attr/epAccent"
                android:foreground="?attr/selectableItemBackground"
                android:padding="8dp"
                android:layout_marginBottom="16dp" />

            <!-- Logo area -->
            <LinearLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:background="@drawable/bg_accent_circle">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/logo_e"
                    android:textColor="?attr/epTextOnPrimary"
                    android:textSize="32sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="28sp"
                android:textColor="?attr/epTextPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tu_companero_productividad"
                android:textSize="14sp"
                android:textColor="?attr/epTextSecondary"
                android:layout_marginBottom="32dp" />

            <!-- Email -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/Widget.Epycus.Input"
                app:startIconDrawable="@drawable/ic_mood_normal"
                app:startIconTint="?attr/epTextTertiary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCorreo"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="@string/correo_hint"
                    android:textColor="?attr/epTextPrimary"
                    android:textColorHint="?attr/epTextTertiary"
                    android:textSize="15sp"
                    android:inputType="textEmailAddress" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                style="@style/Widget.Epycus.Input"
                app:endIconMode="password_toggle"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="?attr/epTextTertiary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etContrasena"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="@string/contrasena_hint"
                    android:textColor="?attr/epTextPrimary"
                    android:textColorHint="?attr/epTextTertiary"
                    android:textSize="15sp"
                    android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Forgot password -->
            <TextView
                android:id="@+id/tvRecuperarContrasena"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/olvidaste_contrasena"
                android:textSize="13sp"
                android:textColor="?attr/epAccent"
                android:layout_marginBottom="24dp"
                android:layout_gravity="end"
                android:foreground="?attr/selectableItemBackground"
                android:padding="4dp" />

            <!-- Login button -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/iniciar_sesion"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:backgroundTint="?attr/epAccent"
                    android:textColor="?attr/epTextOnPrimary"
                    app:cornerRadius="16dp" />

                <ProgressBar
                    android:id="@+id/loadingView"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="?attr/epTextOnPrimary"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- Google button -->
            <LinearLayout
                android:id="@+id/btnGoogleAuth"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:foreground="?attr/selectableItemBackground"
                android:background="@drawable/bg_card_rounded"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:gravity="center"
                    android:text="@string/google_g"
                    android:textSize="16sp"
                    android:textColor="?attr/epAccent"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/continuar_con_google"
                    android:textSize="15sp"
                    android:textColor="?attr/epTextPrimary" />
            </LinearLayout>

            <!-- Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginVertical="16dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="?attr/epSurfaceBorder" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/o_texto"
                    android:textSize="13sp"
                    android:textColor="?attr/epTextTertiary"
                    android:paddingHorizontal="12dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="?attr/epSurfaceBorder" />
            </LinearLayout>

            <!-- Register link -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_tienes_cuenta"
                android:textSize="14sp"
                android:textColor="?attr/epTextSecondary"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegistro"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/crear_cuenta"
                android:textAllCaps="false"
                android:textSize="16sp"
                style="@style/Widget.Epycus.Button.Outline"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
