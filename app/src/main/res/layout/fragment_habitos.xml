<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/epBgPrimary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/habitos_hoy_titulo"
            android:textSize="22sp"
            android:textColor="?attr/epTextPrimary"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvHabitosCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cargando"
            android:textSize="13sp"
            android:textColor="?attr/epTextSecondary"
            android:layout_marginBottom="12dp" />

        <!-- Category Filter Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupCategorias"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleLine="true"
                app:singleSelection="false"
                app:chipSpacing="8dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTodas"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/todas"
                    app:chipBackgroundColor="?attr/epSurface"
                    app:chipStrokeColor="?attr/epAccent"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="18dp"
                    app:chipIconVisible="false"
                    app:checkedIconVisible="false" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- Loading -->
        <LinearLayout
            android:id="@+id/loadingView"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:indeterminateTint="?attr/epAccent" />
        </LinearLayout>

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_habits"
                app:tint="?attr/epTextTertiary"
                android:contentDescription="@null"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/crea_primer_habito"
                android:textSize="15sp"
                android:textColor="?attr/epTextSecondary"
                android:gravity="center" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEmptyCrearHabito"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/crear_primer_habito_btn"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:backgroundTint="?attr/epAccent"
                android:textColor="?attr/epTextOnPrimary"
                app:cornerRadius="24dp"
                android:layout_marginTop="16dp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvHabitos"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNuevoHabito"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/nuevo_habito_btn"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:backgroundTint="?attr/epAccent"
            android:textColor="?attr/epTextOnPrimary"
            app:cornerRadius="16dp"
            android:layout_marginTop="8dp"
            app:icon="@drawable/ic_add"
            app:iconGravity="textStart"
            app:iconTint="?attr/epTextOnPrimary" />

    </LinearLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
