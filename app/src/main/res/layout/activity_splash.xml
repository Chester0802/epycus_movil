<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/epBgPrimary"
    android:gravity="center"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/ivSplashLogo"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:src="@drawable/ic_logo"
        android:scaleType="fitCenter"
        android:contentDescription="@string/app_name" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textColor="?attr/epTextPrimary"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvSplashTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tu_companero_productividad"
        android:textSize="14sp"
        android:textColor="?attr/epTextSecondary"
        android:layout_marginBottom="48dp" />

    <ProgressBar
        android:id="@+id/pbSplash"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:indeterminateTint="?attr/epAccent"
        android:contentDescription="@string/cargando" />

</LinearLayout>
