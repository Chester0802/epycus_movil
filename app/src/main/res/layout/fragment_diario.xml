<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/epBgPrimary">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Loading -->
            <LinearLayout
                android:id="@+id/loadingView"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">
                <ProgressBar
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:indeterminateTint="?attr/epAccent" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/diario_titulo"
                android:textSize="22sp"
                android:textColor="?attr/epTextPrimary"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp" />

            <!-- Guiding Question Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reflexion_del_dia"
                    android:textSize="14sp"
                    android:textColor="?attr/epTextPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvPreguntaGuia"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cargando"
                    android:textSize="16sp"
                    android:textColor="?attr/epAccentSecondary"
                    android:textStyle="italic" />
            </LinearLayout>

            <!-- Mood Selector (5 moods, 100dp each) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/como_te_sientes"
                android:textSize="15sp"
                android:textColor="?attr/epTextPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/moodGenial"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_rounded"
                    android:foreground="?attr/selectableItemBackground">

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginBottom="4dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_mood_genial"
                            android:contentDescription="@null" />

                        <ImageView
                            android:id="@+id/checkGenial"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_check_circle"
                            app:tint="?attr/epSuccess"
                            android:layout_gravity="end|bottom"
                            android:visibility="gone" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/genial"
                        android:textSize="11sp"
                        android:textColor="?attr/epTextPrimary"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/moodBien"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_rounded"
                    android:foreground="?attr/selectableItemBackground">

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginBottom="4dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_mood_bien"
                            android:contentDescription="@null" />

                        <ImageView
                            android:id="@+id/checkBien"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_check_circle"
                            app:tint="?attr/epInfo"
                            android:layout_gravity="end|bottom"
                            android:visibility="gone" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/bien"
                        android:textSize="11sp"
                        android:textColor="?attr/epTextPrimary"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/moodNormal"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_rounded"
                    android:foreground="?attr/selectableItemBackground">

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginBottom="4dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_mood_normal"
                            android:contentDescription="@null" />

                        <ImageView
                            android:id="@+id/checkNormal"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_check_circle"
                            app:tint="?attr/epWarning"
                            android:layout_gravity="end|bottom"
                            android:visibility="gone" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/normal"
                        android:textSize="11sp"
                        android:textColor="?attr/epTextPrimary"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/moodCansado"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_rounded"
                    android:foreground="?attr/selectableItemBackground">

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginBottom="4dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_mood_cansado"
                            android:contentDescription="@null" />

                        <ImageView
                            android:id="@+id/checkCansado"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_check_circle"
                            app:tint="?attr/epWarning"
                            android:layout_gravity="end|bottom"
                            android:visibility="gone" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/cansado"
                        android:textSize="11sp"
                        android:textColor="?attr/epTextPrimary"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/moodEstresado"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_rounded"
                    android:foreground="?attr/selectableItemBackground">

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginBottom="4dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_mood_estresado"
                            android:contentDescription="@null" />

                        <ImageView
                            android:id="@+id/checkEstresado"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_check_circle"
                            app:tint="?attr/epError"
                            android:layout_gravity="end|bottom"
                            android:visibility="gone" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/estresado"
                        android:textSize="11sp"
                        android:textColor="?attr/epTextPrimary"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Daily journal entry -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutDiarioTexto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/Widget.Epycus.Input">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDiarioTexto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/escribe_tu_dia"
                    android:inputType="textMultiLine"
                    android:maxLines="8"
                    android:minLines="4" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardarAnimo"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/guardar_entrada_diario"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:backgroundTint="?attr/epAccent"
                android:textColor="?attr/epTextOnPrimary"
                app:cornerRadius="16dp"
                android:layout_marginBottom="16dp" />

            <!-- Today's Entry Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tu_entrada_hoy"
                    android:textSize="14sp"
                    android:textColor="?attr/epTextPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvEntradaHoy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sin_entrada_hoy"
                    android:textSize="13sp"
                    android:textColor="?attr/epTextSecondary" />
            </LinearLayout>

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/layoutEmptyDiario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_mood_normal"
                    app:tint="?attr/epTextTertiary"
                    android:contentDescription="@null"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sin_contenido_diario"
                    android:textSize="15sp"
                    android:textColor="?attr/epTextSecondary"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Chat with Edy -->
            <LinearLayout
                android:id="@+id/btnChatEdy"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="16dp"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:background="@drawable/bg_accent_circle">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/edy_letra"
                        android:textColor="?attr/epTextOnPrimary"
                        android:textStyle="bold"
                        android:textSize="18sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/habla_con_edy"
                        android:textSize="15sp"
                        android:textColor="?attr/epTextPrimary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/asistente_bienestar"
                        android:textSize="12sp"
                        android:textColor="?attr/epTextSecondary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Mood History -->
            <LinearLayout
                android:id="@+id/layoutHistorial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/historial_animo"
                    android:textSize="16sp"
                    android:textColor="?attr/epTextPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvHistorialAnimo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
