<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/epBgPrimary">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Loading -->
            <LinearLayout
                android:id="@+id/loadingView"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">
                <ProgressBar
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:indeterminateTint="?attr/epAccent" />
            </LinearLayout>

            <!-- Avatar Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:scaleType="fitCenter"
                    android:adjustViewBounds="true"
                    app:strokeWidth="2dp"
                    app:strokeColor="?attr/epAccent"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/usuario"
                    android:textSize="22sp"
                    android:textColor="?attr/epTextPrimary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCorreo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/correo_ejemplo"
                    android:textSize="14sp"
                    android:textColor="?attr/epTextSecondary" />

                <TextView
                    android:id="@+id/tvCarrera"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sin_carrera"
                    android:textSize="13sp"
                    android:textColor="?attr/epTextTertiary"
                    android:layout_marginTop="4dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:background="@drawable/bg_card_rounded"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="4dp"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/tvNivel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/nivel_placeholder"
                        android:textSize="12sp"
                        android:textColor="?attr/epAccent"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_rounded">

                    <TextView
                        android:id="@+id/tvRacha"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/cero_dias"
                        android:textSize="15sp"
                        android:textColor="?attr/epTextPrimary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/racha"
                        android:textSize="11sp"
                        android:textColor="?attr/epTextSecondary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_rounded">

                    <TextView
                        android:id="@+id/tvXp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/cero_xp"
                        android:textSize="15sp"
                        android:textColor="?attr/epAccent"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_xp"
                        android:textSize="11sp"
                        android:textColor="?attr/epTextSecondary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Menu Items -->
            <LinearLayout
                android:id="@+id/btnPersonajes"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_rounded"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="8dp"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="@string/emoji_personajes"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/mis_personajes"
                    android:textSize="14sp"
                    android:textColor="?attr/epTextPrimary"
                    android:layout_marginStart="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chevron_right"
                    android:textSize="16sp"
                    android:textColor="?attr/epTextTertiary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnLogros"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_rounded"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="8dp"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="@string/emoji_logros"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/logros"
                    android:textSize="14sp"
                    android:textColor="?attr/epTextPrimary"
                    android:layout_marginStart="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chevron_right"
                    android:textSize="16sp"
                    android:textColor="?attr/epTextTertiary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnEstadisticas"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_rounded"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="8dp"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="@string/emoji_estadisticas"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/estadisticas"
                    android:textSize="14sp"
                    android:textColor="?attr/epTextPrimary"
                    android:layout_marginStart="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chevron_right"
                    android:textSize="16sp"
                    android:textColor="?attr/epTextTertiary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnConfiguracion"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_rounded"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="8dp"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="@string/emoji_config"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/configuracion"
                    android:textSize="14sp"
                    android:textColor="?attr/epTextPrimary"
                    android:layout_marginStart="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chevron_right"
                    android:textSize="16sp"
                    android:textColor="?attr/epTextTertiary" />
            </LinearLayout>

            <!-- Theme Toggle -->
            <LinearLayout
                android:id="@+id/btnToggleTheme"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_rounded"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:id="@+id/tvThemeIcon"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="@string/emoji_luna"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tvToggleTheme"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/modo_oscuro"
                    android:textSize="14sp"
                    android:textColor="?attr/epTextPrimary"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCerrarSesion"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/cerrar_sesion"
                android:textAllCaps="false"
                android:textSize="15sp"
                style="@style/Widget.Epycus.Button.Outline"
                android:layout_marginBottom="16dp"
                app:cornerRadius="16dp" />

            <TextView
                android:id="@+id/tvMiembroDesde"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="11sp"
                android:textColor="?attr/epTextTertiary"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
