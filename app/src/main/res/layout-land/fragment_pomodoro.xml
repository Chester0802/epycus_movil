<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/epBgPrimary">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
            android:padding="8dp">

            <!-- Loading -->
            <LinearLayout
                android:id="@+id/loadingView"
                android:layout_width="match_parent"
                android:layout_height="60dp"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">
            <ProgressBar
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:indeterminateTint="?attr/epAccent" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pomodoro"
            android:textSize="22sp"
            android:textColor="?attr/epTextPrimary"
            android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <!-- Timer Circle with CircularProgress -->
            <FrameLayout
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_marginTop="12dp">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progressIndicator"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                android:indeterminate="false"
                app:indicatorSize="160dp"
                app:trackThickness="5dp"
                app:trackColor="?attr/epSurfaceBorder"
                app:indicatorColor="?attr/epAccentSecondary" />

            <LinearLayout
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_timer_circle"
                android:gravity="center"
                android:orientation="vertical"
                android:elevation="2dp">

                <TextView
                    android:id="@+id/tvEstado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/foco"
                    android:textSize="13sp"
                    android:textColor="?attr/epTextOnPrimary"
                    android:alpha="0.8"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvTiempo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tiempo_inicial"
                    android:textSize="36sp"
                    android:textColor="?attr/epTextOnPrimary"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/tvSessionLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sesion_inicial"
                    android:textSize="12sp"
                    android:textColor="?attr/epTextOnPrimary"
                    android:alpha="0.67"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </FrameLayout>

        <!-- Control Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnControl"
            android:layout_width="160dp"
            android:layout_height="44dp"
            android:text="@string/iniciar"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:backgroundTint="?attr/epAccent"
            android:textColor="?attr/epTextOnPrimary"
            app:cornerRadius="22dp"
                android:layout_marginTop="12dp"
                app:icon="@drawable/ic_play"
            app:iconGravity="textStart"
            app:iconTint="?attr/epTextOnPrimary" />

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
                android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:gravity="center"
                android:orientation="vertical"
                android:background="@drawable/bg_stat_card">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_pomodoro"
                    app:tint="?attr/epAccent"
                    android:contentDescription="@null"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvCiclos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ciclos_inicial"
                    android:textSize="12sp"
                    android:textColor="?attr/epTextPrimary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ciclos_label"
                    android:textSize="12sp"
                    android:textColor="?attr/epTextTertiary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp"
                android:gravity="center"
                android:orientation="vertical"
                android:background="@drawable/bg_stat_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/streak_emoji"
                    android:textSize="20sp"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvTotalHoy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hoy_inicial"
                    android:textSize="12sp"
                    android:textColor="?attr/epTextPrimary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hoy_label"
                    android:textSize="12sp"
                    android:textColor="?attr/epTextTertiary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:gravity="center"
                android:orientation="vertical"
                android:background="@drawable/bg_stat_card">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_streak"
                    app:tint="?attr/epAccentSecondary"
                    android:contentDescription="@null"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvRacha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/racha_default"
                    android:textSize="12sp"
                    android:textColor="?attr/epTextPrimary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/racha_label"
                    android:textSize="12sp"
                    android:textColor="?attr/epTextTertiary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Tip Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_stat_card"
            android:padding="14dp"
            android:layout_marginTop="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_lightbulb"
                app:tint="?attr/epAccentSecondary"
                android:contentDescription="@null"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tvTip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textColor="?attr/epTextSecondary"
                android:lineSpacingExtra="2dp" />
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
                android:layout_marginTop="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfig"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="@string/configuracion"
                android:textAllCaps="false"
                android:textSize="14sp"
                style="@style/Widget.Epycus.Button.Outline"
                app:icon="@drawable/ic_settings"
                app:iconGravity="textStart"
                app:iconTint="?attr/epAccent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHistorial"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="@string/historial"
                android:textAllCaps="false"
                android:textSize="14sp"
                style="@style/Widget.Epycus.Button.Outline"
                app:icon="@drawable/ic_history"
                app:iconGravity="textStart"
                app:iconTint="?attr/epAccent" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:orientation="vertical" />
    </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
