<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/epBgPrimary">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- Header: Character + Greeting + Level RPG -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="?attr/epAccentLight"
                app:strokeWidth="0dp"
                android:background="@drawable/bg_header_card">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/ivPersonaje"
                        android:layout_centerVertical="true">

                        <TextView
                            android:id="@+id/tvBienvenida"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/hola_formato"
                            android:textSize="22sp"
                            android:textColor="?attr/epTextPrimary"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_level"
                                app:tint="?attr/epAccent"
                                android:layout_marginEnd="6dp"
                                android:contentDescription="@null" />

                            <TextView
                                android:id="@+id/tvNivelTitulo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/nivel_1"
                                android:textSize="14sp"
                                android:textColor="?attr/epAccent"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Glow behind character -->
                    <ImageView
                        android:layout_width="130dp"
                        android:layout_height="150dp"
                        android:layout_marginEnd="4dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/bg_character_glow"
                        android:alpha="0.25"
                        android:contentDescription="@null" />

                    <ImageView
                        android:id="@+id/ivPersonaje"
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:scaleType="fitCenter"
                        android:adjustViewBounds="true"
                        android:contentDescription="@string/mis_personajes" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Offline Banner -->
            <LinearLayout
                android:id="@+id/offlineBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="4dp"
                android:background="?attr/epWarning"
                android:visibility="gone"
                android:layout_marginBottom="4dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_wifi_off"
                    android:contentDescription="@null"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mostrando_datos_sin_conexion"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Loading -->
            <LinearLayout
                android:id="@+id/loadingView"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:gravity="center"
                android:visibility="gone">
                <ProgressBar
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:indeterminateTint="?attr/epAccent" />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/emptyView"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sin_conexion_datos"
                    android:textSize="14sp"
                    android:textColor="?attr/epTextSecondary" />
            </LinearLayout>

            <!-- Stats Cards (2x2 grid con LinearLayouts anidados) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/cardHabitosPendientes"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/bg_card_rounded"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:foreground="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_habits"
                            app:tint="?attr/epAccent"
                            android:layout_marginBottom="4dp"
                            android:contentDescription="@null" />

                        <TextView
                            android:id="@+id/tvHabitosPendientes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cero"
                            android:textSize="20sp"
                            android:textColor="?attr/epTextPrimary"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/habitos"
                            android:textSize="12sp"
                            android:textColor="?attr/epTextSecondary" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/cardRacha"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/bg_card_rounded"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:foreground="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_streak"
                            app:tint="?attr/epWarning"
                            android:layout_marginBottom="4dp"
                            android:contentDescription="@null" />

                        <TextView
                            android:id="@+id/tvRacha"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cero"
                            android:textSize="20sp"
                            android:textColor="?attr/epTextPrimary"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/racha"
                            android:textSize="12sp"
                            android:textColor="?attr/epTextSecondary" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <LinearLayout
                        android:id="@+id/cardNivel"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/bg_card_rounded"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:foreground="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_level"
                            app:tint="?attr/epAccentSecondary"
                            android:layout_marginBottom="4dp"
                            android:contentDescription="@null" />

                        <TextView
                            android:id="@+id/tvNivel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/nv_1"
                            android:textSize="20sp"
                            android:textColor="?attr/epTextPrimary"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/nivel"
                            android:textSize="12sp"
                            android:textColor="?attr/epTextSecondary" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/cardMisionesPendientes"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/bg_card_rounded"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:foreground="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_mision"
                            app:tint="?attr/epAccentSecondary"
                            android:layout_marginBottom="4dp"
                            android:contentDescription="@null" />

                        <TextView
                            android:id="@+id/tvMisionesPendientes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cero"
                            android:textSize="20sp"
                            android:textColor="?attr/epTextPrimary"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/misiones_pendientes_label"
                            android:textSize="12sp"
                            android:textColor="?attr/epTextSecondary" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- XP Progress Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="10dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/tu_progreso"
                        android:textSize="16sp"
                        android:textColor="?attr/epTextPrimary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvXpText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/cero_xp_text"
                        android:textSize="13sp"
                        android:textColor="?attr/epAccent"
                        android:textStyle="bold" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pbXp"
                    android:layout_width="match_parent"
                    android:layout_height="14dp"
                    android:progress="0"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:progressTint="?attr/epAccent"
                    android:progressBackgroundTint="?attr/epSurfaceBorder"
                    android:layout_marginTop="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:id="@+id/tvXpPorcentaje"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/porcentaje_siguiente_nivel_text"
                        android:textSize="12sp"
                        android:textColor="?attr/epTextSecondary" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvSiguienteHito"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="12sp"
                        android:textColor="?attr/epAccentSecondary"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Motivational Quote -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="10dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvFrase"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/frase_motivacional_defecto"
                    android:textSize="14sp"
                    android:textColor="?attr/epTextPrimary"
                    android:textStyle="italic" />

                <TextView
                    android:id="@+id/tvFraseAutor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="?attr/epAccentSecondary"
                    android:layout_marginTop="4dp"
                    android:layout_gravity="end" />
            </LinearLayout>

            <!-- Quick Actions: "Tus habilidades" -->
            <TextView
                android:id="@+id/tvHabilidadesLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu_habilidades"
                android:textSize="16sp"
                android:textColor="?attr/epTextPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAddHabit"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="?attr/epSurface"
                    app:cardElevation="3dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/epSurfaceBorder"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/ic_habits"
                            app:tint="?attr/epAccent"
                            android:layout_marginBottom="8dp"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/nuevo_habito"
                            android:textColor="?attr/epTextPrimary"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:gravity="center" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMision"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="3dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="?attr/epSurface"
                    app:cardElevation="3dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/epSurfaceBorder"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/ic_mision"
                            app:tint="?attr/epAccentSecondary"
                            android:layout_marginBottom="8dp"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mision_diaria"
                            android:textColor="?attr/epTextPrimary"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:gravity="center" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFocus"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="?attr/epSurface"
                    app:cardElevation="3dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/epSurfaceBorder"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/ic_pomodoro"
                            app:tint="?attr/epAccent"
                            android:layout_marginBottom="8dp"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/modo_enfoque"
                            android:textColor="?attr/epTextPrimary"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:gravity="center" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
